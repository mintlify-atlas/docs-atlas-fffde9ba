  "keyFeatures": [
    "Unified vehicle control API for drones (Drone) and ground vehicles (Rover) via MAVSDK",
    "Scriptable missions with BasicRunner (linear) and StateMachine (state-based) runners",
    "Multi-vehicle ZMQ coordination for leader/follower and swarm missions",
    "Built-in safety checker with KML geofence validation and command pre-validation",
    "QGroundControl .plan file support for pre-planned waypoint missions",
    "Async-first v2 API with non-blocking VehicleTask commands and cancellation",
    "Background task execution parallel to main state machine",
    "AERPAW platform integration with OEO logging and checkpointing",
    "ExternalProcess utility for spawning and communicating with subprocesses",
    "ArduPilot SITL simulation support for local development and testing"
  ],
